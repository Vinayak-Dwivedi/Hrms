{
  "name": "hrms-api",
  "version": "0.1.0",
  "description": "HRMS REST API — Express + Drizzle + JWT (bcrypt + httpOnly cookies, Bearer also accepted).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:baseline": "node scripts/baseline-drizzle-migrations.mjs",
    "db:verify-onboarding": "node scripts/verify-onboarding-schema.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:migrate-drizzle-kit": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:users": "node scripts/seed-users.mjs",
    "seed:admin": "node scripts/seed-admin.mjs",
    "seed:master": "node scripts/seed-master.mjs",
    "seed:hrms": "node scripts/seed-hrms-demo.mjs",
    "seed:holidays": "node scripts/seed-holidays.mjs",
    "seed:rbac": "node scripts/seed-rbac.mjs",
    "seed:onboarding-permissions": "node scripts/ensure-onboarding-permissions.mjs",
    "db:migrate-designation-code": "node scripts/apply-designation-code-schema.mjs",
    "db:migrate-personal-email-verification": "node scripts/apply-personal-email-verification-schema.mjs",
    "db:migrate-phone-verification": "node scripts/apply-phone-verification-schema.mjs",
    "db:migrate-sensitive-schema": "node scripts/apply-sensitive-schema.mjs",
    "db:migrate-org-hierarchy": "node scripts/apply-org-hierarchy-schema.mjs && node scripts/apply-org-hierarchy-merge-level-grade.mjs",
    "db:migrate-org-hierarchy-merge": "node scripts/apply-org-hierarchy-merge-level-grade.mjs",
    "db:migrate-employee-org-hierarchy": "node scripts/apply-employee-org-hierarchy-structure.mjs",
    "db:migrate-onboarding-bank-approval": "node scripts/apply-onboarding-bank-approval-schema.mjs",
    "db:migrate-onboarding-phase3": "node scripts/apply-onboarding-phase3-document-rejection.mjs",
    "db:migrate-onboarding-pending": "node scripts/apply-onboarding-pending-migrations.mjs",
    "db:migrate-leave-policy": "node scripts/apply-leave-policy-schema.mjs",
    "db:migrate-holiday-calendar": "node scripts/apply-holiday-calendar-schema.mjs",
    "db:migrate-employee-sub-department": "node scripts/apply-employee-sub-department-schema.mjs",
    "db:migrate-weekly-off": "node scripts/apply-weekly-off-schema.mjs",
    "db:migrate-leave-credit": "node scripts/apply-leave-credit-schema.mjs",
    "seed:org-hierarchy": "node scripts/seed-org-hierarchy.mjs",
    "migrate:encrypt-sensitive": "node scripts/apply-sensitive-schema.mjs && node scripts/migrate-encrypt-sensitive-fields.mjs",
    "test": "node --import tsx --test src/lib/sensitive-field-crypto.test.ts src/lib/sensitive-employee-fields.test.ts src/lib/auth-credentials.test.ts src/lib/employee-auth.test.ts src/middleware/require-permission.test.ts src/modules/org-hierarchy/services/org-hierarchy-tree.test.ts src/modules/org-hierarchy/services/org-hierarchy-validation.test.ts src/modules/org-hierarchy/services/employee-reporting-tree.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^1.0.0-beta.22",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.5",
    "rate-limit-redis": "^5.0.0",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.23",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^1.0.0-beta.22",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0"
  }
}
