# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hrms_dev

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Comma-separated. Used by CORS (dev only). Frontend dev runs at :3000.
# In prod, leave empty — nginx proxies same-origin and CORS is unused.
CORS_ORIGINS=http://10.24.24.248:3000

# Body size limit (bytes). 1 MB default.
BODY_LIMIT_BYTES=1048576

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-32-bytes-min
JWT_REFRESH_SECRET=replace-me-32-bytes-min-distinct
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Cookies ──────────────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true in production (requires HTTPS).
COOKIE_SECURE=false
COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=hrms_at
REFRESH_COOKIE_NAME=hrms_rt

# ── Rate limit ───────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# ── Seeded credentials (used by scripts/seed-users.mjs) ──────────────────────
SEED_EMPLOYEE_PASSWORD=Employee@12345!
SEED_MANAGER_PASSWORD=Manager@12345!

# Master bootstrap user (scripts/seed-master.mjs)
SEED_MASTER_EMAIL=admin@iotindia.ai
SEED_MASTER_PASSWORD=123456
SEED_MASTER_NAME="Master Admin"

# ── Field encryption (required outside NODE_ENV=test) ───────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
ENCRYPTION_INDEX_KEY=

ALLOWED_DEV_ORIGINS=10.24.24.248
REDIS_URL=

# ── SMS (optional — phone OTP logs to console in development when unset) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Support email ─────────────────────────────────────────────────────────────
SUPPORT_EMAIL=support@iotindia.ai
SUPPORT_PHONE=+91-9720171203
SUPPORT_WEBSITE=https://iotindia.ai
SUPPORT_NAME=IOT India
SUPPORT_ADDRESS=Commercial Complex behind Kailash Tower,
SUPPORT_CITY=Dehradun
SUPPORT_STATE=Uttarakhand
SUPPORT_ZIP=248001
SUPPORT_COUNTRY=India
