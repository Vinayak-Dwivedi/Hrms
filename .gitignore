# Per-service gitignores live under frontend/ and hrms-api/. This top-level
# file covers anything that's a monorepo concern.

# Local backups of the pre-split per-service histories. Keep out of git; the
# bundles are large and only useful as a recovery archive on the laptop.
/.git-backups/

# Tooling
.claude/
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Catch-all for env files anywhere in the tree (belt-and-braces; each
# service's own .gitignore already covers the common cases).
**/.env
**/.env.local
**/.env.*.local

# Never commit private keys
*.pem
*.key
